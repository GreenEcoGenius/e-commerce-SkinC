<section
  class="isyf-full-banner"
  {% if section.settings.image != blank %}
    style="background-image: url({{ section.settings.image | image_url: width: 2000 }});"
  {% endif %}
>
  <div class="isyf-full-banner__overlay"></div>
  <div class="isyf-full-banner__content">
    {% if section.settings.subtitle != blank %}
      <span class="isyf-full-banner__subtitle">{{ section.settings.subtitle }}</span>
    {% endif %}
    {% if section.settings.title != blank %}
      <h2 class="isyf-full-banner__title">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.button_label != blank %}
      {% render 'button', label: section.settings.button_label, variant: 'bright', href: section.settings.button_link %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Full image banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Every design carries a message"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "FEEL SOMETHING"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Full image banner",
      "settings": {
        "subtitle": "Every design carries a message",
        "title": "FEEL SOMETHING",
        "button_label": "SHOP NOW"
      }
    }
  ]
}
{% endschema %}
