        { "type": "url", "id": "col1_link1_url", "label": "Col 1 link 1 URL" },
        { "type": "text", "id": "col1_link2_label", "label": "Col 1 link 2 label", "default": "T-shirts" },
        { "type": "url", "id": "col1_link2_url", "label": "Col 1 link 2 URL" },
        { "type": "text", "id": "col1_link3_label", "label": "Col 1 link 3 label", "default": "Limited Drops" },
        { "type": "url", "id": "col1_link3_url", "label": "Col 1 link 3 URL" },
        { "type": "text", "id": "col2_title", "label": "Column 2 title", "default": "ISYF FEELS" },
        { "type": "text", "id": "col2_link1_label", "label": "Col 2 link 1 label", "default": "T-shirts à message" },
        { "type": "url", "id": "col2_link1_url", "label": "Col 2 link 1 URL" },
        { "type": "text", "id": "col2_link2_label", "label": "Col 2 link 2 label", "default": "Sweats imprimés" },
