<div style="width: 100%; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--Black); color: var(--White); padding: 40px; text-align: center;">
  <h1 style="font-family: 'Playfair Display', serif; font-size: 48px; font-weight: 400; letter-spacing: 0.12em; margin: 0 0 16px;">{{ shop.name }}</h1>
  <p style="font-size: 15px; font-weight: 300; color: rgba(255,255,255,0.7); margin: 0 0 32px; max-width: 400px;">{{ section.settings.heading | default: 'We are getting ready. Enter your password to access the store.' }}</p>

  {% form 'storefront_password' %}
    <div style="display: flex; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.4); max-width: 360px; margin: 0 auto; padding: 12px 0;">
      <input type="password" name="password" placeholder="Enter store password" style="flex: 1; border: none; outline: none; background: transparent; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 300; color: var(--White);">
      <button type="submit" style="background: none; border: none; font-size: 18px; cursor: pointer; color: var(--White);">&rarr;</button>
    </div>
    {% if form.errors %}
      <p style="color: var(--Red); margin-top: 16px; font-size: 14px;">{{ form.errors | default_errors }}</p>
    {% endif %}
  {% endform %}
</div>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading text",
      "default": "We are getting ready. Enter your password to access the store."
    }
  ],
  "presets": [
    {
      "name": "Password page"
    }
  ]
}
{% endschema %}
