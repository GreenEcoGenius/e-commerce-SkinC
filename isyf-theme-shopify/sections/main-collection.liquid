<div class="isyf-shop-page">
  <div class="isyf-shop__content">
    <h1 class="isyf-shop__title">{{ collection.title }}</h1>

    {% if collection.description != blank %}
      <p style="text-align: center; font-size: 14px; font-weight: 300; color: var(--Gray-3); margin: 0 0 32px;">{{ collection.description }}</p>
    {% endif %}

    {% if section.settings.show_filter_bar %}
      <div class="isyf-shop__filter-bar">
        <a href="/collections/all" class="isyf-shop__filter-btn{% if collection.handle == 'all' %} isyf-shop__filter-btn--active{% endif %}">All</a>
        {% for block in section.blocks %}
          {% if block.type == 'filter_link' %}
            <a
              href="{{ block.settings.link }}"
              class="isyf-shop__filter-btn{% if collection.handle == block.settings.collection_handle %} isyf-shop__filter-btn--active{% endif %}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.label }}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% paginate collection.products by section.settings.products_per_page %}
      <div class="isyf-shop__product-grid">
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% else %}
          <p class="isyf-shop__empty-text">No products found.</p>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div style="display: flex; justify-content: center; gap: 8px; margin-top: 48px;">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="isyf-btn isyf-btn--dark">&larr; Previous</a>
          {% endif %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="isyf-btn isyf-btn--dark">Next &rarr;</a>
          {% endif %}
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</div>

{% schema %}
{
  "name": "Collection page",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 6,
      "max": 48,
      "step": 3,
      "label": "Products per page",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_filter_bar",
      "label": "Show filter bar",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "filter_link",
      "name": "Filter link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Women"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "collection_handle",
          "label": "Collection handle (for active state)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection page",
      "blocks": [
        { "type": "filter_link", "settings": { "label": "Women", "collection_handle": "women" } },
        { "type": "filter_link", "settings": { "label": "Men", "collection_handle": "men" } },
        { "type": "filter_link", "settings": { "label": "Accessories", "collection_handle": "accessories" } }
      ]
    }
  ]
}
{% endschema %}
